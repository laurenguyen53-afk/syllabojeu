// ══ API GEMINI ══
async function callGemini(prompt,maxTokens){
  const url='https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key='+GEMINI_API_KEY;
  const res=await fetch(url,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      contents:[{parts:[{text:prompt}]}],
      generationConfig:{maxOutputTokens:maxTokens,temperature:0.7}
    })
  });
  const data=await res.json();
  return data.candidates?.[0]?.content?.parts?.[0]?.text||'';
}

async function generateWordIA(level){
  const n={1:2,2:3,3:4}[level];
  const usedList=[...usedWords].slice(-20).join(', ');
  const txt=await callGemini(
    `Expert phonologie FLE enfants. UN mot français concret avec EXACTEMENT ${n} syllabes orales. Évite : ${usedList||'rien'}. Exemples corrects : soleil=["so","leil"], bateau=["ba","teau"], papillon=["pa","pi","llon"], voiture=["voi","ture"], dentelle=["den","tel","le"]. JSON UNIQUEMENT : {"mot":"soleil","syllabes":["so","leil"],"emoji":"☀️","bg":"#FFF8DC"}`,
    200
  );
  const match=txt.match(/\{[\s\S]*?\}/);
  if(!match)throw new Error('invalide');
  const obj=JSON.parse(match[0]);
  if(!obj.mot||!obj.syllabes||obj.syllabes.length!==n)throw new Error('invalide');
  return obj;
}

async function generateInventedImageSVG(inventedWord){
  const txt=await callGemini(
    `Illustrateur enfants. Mot inventé : "${inventedWord}". SVG viewBox="0 0 150 140", créature drôle colorée, fond pastel, cartoon, PAS de texte. SVG brut commençant par <svg`,
    900
  );
  const match=txt.match(/<svg[\s\S]*<\/svg>/i);
  return match?match[0]:null;
}

function getFallback(level){const list=FALLBACK[level];const idx=fallbackIdx[level]%list.length;fallbackIdx[level]++;return list[idx];}
function setLevel(lvl){
  currentLevel=lvl;
  document.querySelectorAll('.lvl-btn').forEach((b,i)=>b.classList.toggle('active',i+1===lvl));
}

async function loadWord(){
  if(isLoading)return;
  isLoading=true; placed=[]; currentWord=null;
  _syllabationReussie=false; _smileyCourant='😐'; _essaisCourants=0;
  document.getElementById('feedback').innerHTML='';
  document.getElementById('invented-container').innerHTML='';
  document.getElementById('speaking-bar').textContent='';
  document.getElementById('target-zone').innerHTML='<span style="font-size:0.85rem;color:#D4B49A;font-family:Andika,sans-serif;">clique sur une syllabe...</span>';
  document.getElementById('pool').innerHTML='';
  document.getElementById('prononce-zone').classList.remove('active');
  document.getElementById('btn-next').style.display='none';
  document.getElementById('btn-validate').style.display='';
  const outer=document.getElementById('puzzle-outer');
  outer.innerHTML='<div class="dots"><span></span><span></span><span></span></div>';
  outer.classList.remove('solved'); outer.style.borderColor='#F5D5C0'; outer.style.boxShadow='none';
  document.getElementById('btn-placed').disabled=true;

  let obj=null;
  if(mode==='custom'&&customList.length>0){
    if(customQueue.length===0)customQueue=shuffle([...customList]);
    obj={...customQueue.shift()};
  } else {
    try{
      const timeout=new Promise((_,r)=>setTimeout(()=>r(new Error('timeout')),8000));
      obj=await Promise.race([generateWordIA(currentLevel),timeout]);
      if(!obj||usedWords.has(obj.mot))obj=getFallback(currentLevel);
    }catch(e){obj=getFallback(currentLevel);}
  }

  usedWords.add(obj.mot);
  currentWord=obj;
  srcCanvas=drawEmojiToCanvas(currentWord.emoji,currentWord.bg);
  outer.innerHTML='';
  renderPuzzle();
  renderPool(shuffle([...currentWord.syllabes]));
  document.getElementById('btn-placed').disabled=true;
  isLoading=false;
}

function renderPuzzle(){
  const outer=document.getElementById('puzzle-outer'); outer.innerHTML='';
  const syls=currentWord.syllabes,n=syls.length,W=150,bandW=Math.floor(W/n);
  const isCorrect=placed.length===n&&placed.join('')===syls.join('');
  const remaining=syls.filter(s=>!placed.includes(s));
  const displayOrder=[...placed,...remaining];
  displayOrder.forEach((syl,pos)=>{
    const sylIndex=syls.indexOf(syl);
    const isPlaced=placed.includes(syl);
    const w=(pos===n-1)?(W-pos*bandW):bandW;
    if(pos>0){const sep=document.createElement('div');sep.className='band-sep';sep.style.left=(pos*bandW)+'px';outer.appendChild(sep);}
    const band=document.createElement('div');
    band.className='band '+(isCorrect?'lit':isPlaced?'lit':'dark');
    band.style.left=(pos*bandW)+'px'; band.style.width=w+'px';
    if(isPlaced&&!isCorrect)band.style.transform='translateY(-3px)';
    const bc=document.createElement('canvas'); bc.width=150; bc.height=150;
    bc.style.cssText='position:absolute;top:0;left:'+(-sylIndex*bandW)+'px;width:150px;height:150px;';
    bc.getContext('2d').drawImage(srcCanvas,0,0,150,150);
    band.appendChild(bc);
    const lbl=document.createElement('div'); lbl.className='band-syl'; lbl.textContent=syl; band.appendChild(lbl);
    outer.appendChild(band);
  });
  if(isCorrect){outer.classList.add('solved');outer.style.borderColor='#2A9D8F';outer.style.boxShadow='0 0 0 4px rgba(42,157,143,0.2)';}
  else{outer.classList.remove('solved');outer.style.borderColor='#F5D5C0';outer.style.boxShadow='none';}
}

function renderPool(syllables){
  const pool=document.getElementById('pool'); pool.innerHTML='';
  syllables.forEach((syl,i)=>{
    const btn=document.createElement('button'); btn.className='syl-btn'; btn.textContent=syl;
    btn.style.background=PALETTE[i%PALETTE.length]; btn.dataset.syl=syl;
    btn.onclick=()=>pickSyl(btn,syl); pool.appendChild(btn);
  });
}

function pickSyl(btn,syl){
  if(btn.classList.contains('used'))return;
  btn.classList.add('used'); placed.push(syl);
  showBar(currentWord.mot+' (lentement)'); speak(currentWord.mot,0.45);
  renderTarget(); renderPuzzle(); updatePlacedBtn();
}

function renderTarget(){
  const zone=document.getElementById('target-zone'); zone.innerHTML='';
  if(placed.length===0){zone.innerHTML='<span style="font-size:0.85rem;color:#D4B49A;font-family:Andika,sans-serif;">clique sur une syllabe...</span>';return;}
  placed.forEach((syl,i)=>{
    const btn=document.createElement('button'); btn.className='syl-placed';
    btn.style.background=PALETTE[i%PALETTE.length]; btn.textContent=syl;
    btn.onclick=()=>removeSyl(i,syl); zone.appendChild(btn);
  });
}

function removeSyl(idx,syl){
  placed.splice(idx,1); renderTarget(); renderPuzzle(); updatePlacedBtn();
  document.querySelectorAll('.syl-btn').forEach(b=>{if(b.dataset.syl===syl&&b.classList.contains('used'))b.classList.remove('used');});
}

function updatePlacedBtn(){document.getElementById('btn-placed').disabled=placed.length===0;}

function listenPlaced(){
  if(placed.length===0)return;
  const btn=document.getElementById('btn-placed'); btn.textContent='🔈 Lecture...';
  showBar(placed.join(''));
  document.getElementById('feedback').innerHTML='<span>Je lis : '+placed.join(' — ')+'</span>';
  speak(placed.join(''),0.75,()=>{btn.textContent='👂 Ma tentative';});
}

function resetWord(){loadWord();}
function nextWord(){loadWord();}

async function generateInventedImage(inventedWord){
  const inv=document.getElementById('invented-container');
  inv.innerHTML='<div class="invented-box"><div class="invented-title">✨ Tu as inventé : "'+inventedWord+'" !</div><div class="dots"><span></span><span></span><span></span></div></div>';
  try{
    const svg=await generateInventedImageSVG(inventedWord);
    const safe=inventedWord.replace(/'/g,"\\'");
    inv.innerHTML='<div class="invented-box" onclick="speak(\''+safe+'\',0.82)"><div class="invented-title">✨ Tu as inventé : "'+inventedWord+'" !</div>'+(svg||'<div style="font-size:3rem">🌀✨</div>')+'<div class="invented-desc">🔊 Clique pour l\'entendre !</div></div>';
  }catch(e){
    const safe=inventedWord.replace(/'/g,"\\'");
    inv.innerHTML='<div class="invented-box" onclick="speak(\''+safe+'\',0.82)"><div class="invented-title">✨ Mot inventé : "'+inventedWord+'" !</div><div style="font-size:2.8rem">🌈🐾✨</div><div class="invented-desc">🔊 Clique pour l\'entendre !</div></div>';
  }
}

function validateWord(){
  const syls=currentWord.syllabes,attempt=placed.join(''),correct=syls.join('');
  const fb=document.getElementById('feedback');
  if(placed.length===0){fb.innerHTML='<span>👆 Place d\'abord des syllabes !</span>';return;}
  if(attempt===correct){
    score+=10; document.getElementById('score').textContent=score;
    fb.innerHTML='<span>🎉 Bravo ! C\'est <strong>'+currentWord.mot+'</strong> !</span>';
    _syllabationReussie=true;
    renderPuzzle();
    document.getElementById('invented-container').innerHTML='';
    setTimeout(()=>initPrononceZone(),600);
  } else {
    fb.innerHTML='<span>🤔 Presque... tu as inventé "'+attempt+'" !</span>';
    speak('Pas tout à fait, mais tu as inventé le mot '+attempt,0.82);
    _syllabationReussie=false;
    renderPuzzle();
    document.getElementById('stars').textContent='⭐☆☆';
    // Sauvegarder l'échec de syllabation
    sauvegarderResultat(currentWord.mot, false, '😬', 0, '😬');
    generateInventedImage(attempt);
  }
}

// ══ INIT ══
initSelectionScreen();

// ══ GESTION FIN DE SESSION ══
function ouvrirFinSession() {
  const scoreActuel = document.getElementById('score').textContent;
  document.getElementById('modal-score-val').textContent = scoreActuel;
  document.getElementById('session-modal').classList.add('open');
}

function nouvelleSession() {
  // Fermer la modal
  document.getElementById('session-modal').classList.remove('open');
  // Réinitialiser le score et l'état du jeu sans changer d'élève
  score = 0;
  document.getElementById('score').textContent = '0';
  document.getElementById('stars').textContent = '⭐⭐⭐';
  placed = [];
  usedWords.clear();
  document.getElementById('prononce-zone').classList.remove('active');
  document.getElementById('feedback').innerHTML = '';
  document.getElementById('invented-container').innerHTML = '';
  // Lancer un nouveau mot
  loadWord();
}

function changerEleveDepuisModal() {
  document.getElementById('session-modal').classList.remove('open');
  changerEleve();
}
</script>

