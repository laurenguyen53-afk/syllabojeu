<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SyllaboJeu 🧩</title>
<link href="https://fonts.googleapis.com/css2?family=Andika:wght@400;700&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Quicksand',sans-serif;background:#F5EDE4;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px;}
#app{background:#FFF9F0;border-radius:24px;padding:1.6rem 1.4rem 2rem;max-width:640px;width:100%;box-shadow:0 8px 32px rgba(232,114,74,0.12);}
h1{font-family:'Quicksand',sans-serif;font-size:2rem;font-weight:700;color:#E8724A;text-align:center;margin-bottom:0.2rem;}
.tagline{text-align:center;font-size:0.78rem;color:#C49A7A;font-weight:600;margin-bottom:1rem;}
.score-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.8rem;font-size:0.8rem;color:#C49A7A;font-weight:600;}
.top-controls{display:flex;justify-content:center;gap:8px;margin-bottom:0.9rem;align-items:center;flex-wrap:wrap;}
.level-bar{display:flex;gap:6px;}
.lvl-btn{font-family:'Quicksand',sans-serif;font-size:0.72rem;font-weight:700;padding:5px 14px;border-radius:20px;border:2px solid #F5C4A0;background:white;color:#C49A7A;cursor:pointer;transition:all 0.2s;}
.lvl-btn.active{background:#E8724A;border-color:#E8724A;color:white;}
.btn-perso{font-family:'Quicksand',sans-serif;font-size:0.72rem;font-weight:700;padding:5px 14px;border-radius:20px;border:2px solid #A8DADC;background:white;color:#2A9D8F;cursor:pointer;transition:all 0.2s;}
.btn-perso.active-mode{background:#2A9D8F;color:white;border-color:#2A9D8F;}
#perso-panel{background:white;border:2px solid #A8DADC;border-radius:16px;padding:14px;margin-bottom:0.9rem;display:none;}
#perso-panel.open{display:block;}
.perso-title{font-size:0.75rem;font-weight:700;color:#2A9D8F;margin-bottom:8px;}
.perso-desc{font-size:0.68rem;color:#555;margin-bottom:10px;line-height:1.5;background:#F0FBF9;padding:8px;border-radius:8px;}
.add-form{display:flex;gap:6px;flex-wrap:wrap;align-items:flex-end;margin-bottom:10px;}
.add-form input{font-family:'Andika',sans-serif;font-size:0.85rem;border:1.5px solid #A8DADC;border-radius:8px;padding:6px 8px;outline:none;color:#444;}
.add-form input:focus{border-color:#2A9D8F;}
#inp-mot{flex:1;min-width:80px;}
#inp-syls{flex:2;min-width:120px;}
.btn-add{font-family:'Quicksand',sans-serif;font-weight:700;font-size:0.72rem;padding:7px 14px;border-radius:8px;border:none;background:#E8724A;color:white;cursor:pointer;}
.word-list{display:flex;flex-direction:column;gap:6px;margin-bottom:10px;max-height:200px;overflow-y:auto;}
.word-row{display:flex;align-items:center;gap:6px;background:#FFFAF5;border:1.5px solid #F5D5C0;border-radius:10px;padding:6px 8px;}
.word-emoji-btn{font-size:1.4rem;cursor:pointer;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:8px;border:1.5px solid #F5C4A0;background:white;flex-shrink:0;}
.word-emoji-btn:hover{background:#FFF0E8;}
.word-mot{font-family:'Andika',sans-serif;font-size:0.9rem;font-weight:700;color:#444;flex:1;}
.word-syls{font-family:'Andika',sans-serif;font-size:0.75rem;color:#2A9D8F;font-weight:700;}
.word-del{font-size:0.7rem;cursor:pointer;color:#F4978E;background:none;border:none;padding:2px 6px;border-radius:6px;}
.word-del:hover{background:#FCE4EC;}
#emoji-picker{background:white;border:2px solid #F5C4A0;border-radius:14px;padding:10px;margin-bottom:10px;display:none;}
#emoji-picker.open{display:block;}
.emoji-picker-title{font-size:0.65rem;color:#C49A7A;font-weight:700;margin-bottom:6px;text-transform:uppercase;}
.emoji-cats{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px;}
.emoji-cat{font-size:0.62rem;padding:3px 8px;border-radius:10px;border:1.5px solid #F5C4A0;background:white;color:#C49A7A;cursor:pointer;font-family:'Quicksand',sans-serif;font-weight:700;}
.emoji-cat.active{background:#F4A261;color:white;border-color:#F4A261;}
.emoji-grid{display:flex;flex-wrap:wrap;gap:4px;max-height:110px;overflow-y:auto;}
.emoji-opt{font-size:1.4rem;cursor:pointer;width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:8px;border:1.5px solid transparent;}
.emoji-opt:hover{background:#FFF0E8;border-color:#F5C4A0;}
.perso-btns{display:flex;gap:8px;justify-content:flex-end;margin-top:8px;}
.btn-small{font-family:'Quicksand',sans-serif;font-weight:700;font-size:0.72rem;padding:6px 14px;border-radius:10px;border:none;cursor:pointer;}
.btn-apply{background:#2A9D8F;color:white;}
.btn-reset-perso{background:#F5EDE4;color:#C49A7A;}
.mode-badge{font-size:0.65rem;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block;}
.mode-ia{background:#FFF0E8;color:#E8724A;}
.mode-custom{background:#E1F5F3;color:#2A9D8F;}
.main-area{display:flex;gap:12px;margin-bottom:0.9rem;align-items:flex-start;}
.puzzle-wrap{flex:0 0 175px;background:white;border-radius:20px;padding:12px;text-align:center;border:2px solid #F5D5C0;}
.puzzle-label{font-size:0.62rem;color:#C49A7A;font-weight:700;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;}
#puzzle-outer{position:relative;width:150px;height:150px;margin:0 auto;border-radius:14px;overflow:hidden;border:2.5px solid #F5D5C0;transition:border-color 0.5s,box-shadow 0.5s;background:#EEE;display:flex;align-items:center;justify-content:center;}
#puzzle-outer.solved{border-color:#2A9D8F;box-shadow:0 0 0 4px rgba(42,157,143,0.2);}
#emoji-canvas{display:none;position:absolute;top:-9999px;}
.band{position:absolute;top:0;height:150px;overflow:hidden;transition:filter 0.3s;}
.band.lit{filter:brightness(1);}
.band.dark{filter:brightness(0.22) saturate(0.1);}
.band canvas{position:absolute;top:0;left:0;width:150px;height:150px;}
.band-syl{position:absolute;bottom:5px;left:0;right:0;text-align:center;z-index:10;font-family:'Andika',sans-serif;font-size:1.05rem;font-weight:700;color:white;text-shadow:0 0 8px #000,0 2px 4px #000;}
.band-sep{position:absolute;top:0;bottom:0;width:2px;background:rgba(255,255,255,0.5);z-index:8;}
.drop-area{flex:1;background:white;border-radius:20px;padding:12px;border:2px solid #F5D5C0;}
.drop-label{font-size:0.62rem;color:#C49A7A;font-weight:700;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;}
.target-zone{min-height:58px;border:2.5px dashed #F5C4A0;border-radius:14px;display:flex;align-items:center;justify-content:center;gap:6px;padding:8px;flex-wrap:wrap;margin-bottom:8px;background:#FFFAF5;}
.syl-placed{font-family:'Andika',sans-serif;font-size:1.25rem;font-weight:700;border-radius:12px;padding:6px 14px;border:none;cursor:pointer;color:white;animation:popIn 0.2s ease;transition:transform 0.1s;box-shadow:0 3px 0 rgba(0,0,0,0.12);}
.syl-placed:hover{transform:scale(1.07);}
@keyframes popIn{0%{transform:scale(0.4);opacity:0}80%{transform:scale(1.08)}100%{transform:scale(1);opacity:1}}
.pool-area{background:white;border-radius:20px;padding:12px;margin-bottom:0.9rem;border:2px solid #F5D5C0;}
.pool-label{font-size:0.62rem;color:#C49A7A;font-weight:700;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;}
.pool-row{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;}
.syl-btn{font-family:'Andika',sans-serif;font-size:1.15rem;font-weight:700;padding:9px 20px;border-radius:14px;border:none;cursor:pointer;color:white;box-shadow:0 4px 0 rgba(0,0,0,0.12);transition:transform 0.15s,box-shadow 0.15s,opacity 0.2s;}
.syl-btn:hover{transform:translateY(-2px);box-shadow:0 6px 0 rgba(0,0,0,0.12);}
.syl-btn:active{transform:translateY(2px);box-shadow:0 2px 0 rgba(0,0,0,0.12);}
.syl-btn.used{opacity:0.2;cursor:default;pointer-events:none;}
.btns{display:flex;gap:7px;justify-content:center;flex-wrap:wrap;margin-bottom:0.9rem;}
.btn{font-family:'Quicksand',sans-serif;font-weight:700;font-size:0.78rem;padding:8px 14px;border-radius:14px;border:none;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;gap:5px;box-shadow:0 3px 0 rgba(0,0,0,0.1);}
.btn:active{transform:translateY(2px);}
.btn:hover{transform:translateY(-1px);}
.btn-placed{background:#2A9D8F;color:white;}
.btn-reset{background:#F5EDE4;color:#C49A7A;}
.btn-validate{background:#2A9D8F;color:white;}
.btn-next{background:#E9C46A;color:#5A4200;}
.btn:disabled{opacity:0.35;cursor:default;transform:none;}
.btn-end-session{font-family:'Quicksand',sans-serif;font-size:0.7rem;font-weight:700;padding:4px 12px;border-radius:20px;border:2px solid #F4978E;background:white;color:#F4978E;cursor:pointer;transition:all 0.2s;}
.btn-end-session:hover{background:#F4978E;color:white;}
#session-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.45);z-index:9999;align-items:center;justify-content:center;}
#session-modal.open{display:flex;}
.modal-box{background:#FFF9F0;border-radius:24px;padding:2rem 2rem 1.5rem;max-width:340px;width:90%;text-align:center;box-shadow:0 12px 40px rgba(232,114,74,0.2);animation:popIn 0.25s ease;}
.modal-title{font-family:'Quicksand',sans-serif;font-size:1.4rem;font-weight:700;color:#E8724A;margin-bottom:0.5rem;}
.modal-emoji{font-size:3rem;margin-bottom:0.8rem;}
.modal-score{font-family:'Andika',sans-serif;font-size:1rem;color:#C49A7A;margin-bottom:1.4rem;}
.modal-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.btn-modal-new{font-family:'Quicksand',sans-serif;font-weight:700;font-size:0.85rem;padding:10px 20px;border-radius:14px;border:none;background:#E8724A;color:white;cursor:pointer;box-shadow:0 3px 0 rgba(0,0,0,0.1);}
.btn-modal-new:hover{background:#d4633c;}
.btn-modal-change{font-family:'Quicksand',sans-serif;font-weight:700;font-size:0.85rem;padding:10px 20px;border-radius:14px;border:2px solid #C49A7A;background:white;color:#C49A7A;cursor:pointer;}
.btn-modal-change:hover{background:#F5EDE4;}
.feedback{text-align:center;min-height:32px;font-family:'Andika',sans-serif;font-size:1rem;font-weight:700;color:#E8724A;margin-bottom:0.4rem;}
.speaking-bar{text-align:center;font-size:0.7rem;color:#F4A261;font-weight:600;min-height:18px;margin-bottom:4px;font-family:'Quicksand',sans-serif;}
#prononce-zone{background:white;border:2px solid #2A9D8F;border-radius:18px;padding:16px;margin-bottom:0.9rem;text-align:center;display:none;animation:fadeUp 0.3s ease;}
#prononce-zone.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.prononce-title{font-family:'Andika',sans-serif;font-size:1rem;font-weight:700;color:#2A9D8F;margin-bottom:10px;}
.smiley-row{font-size:4rem;margin:8px 0;line-height:1;transition:all 0.4s;}
.smiley-msg{font-family:'Andika',sans-serif;font-size:0.85rem;font-weight:700;margin-bottom:12px;min-height:22px;}
.essais-row{display:flex;gap:8px;justify-content:center;margin-bottom:12px;}
.essai-dot{width:14px;height:14px;border-radius:50%;background:#F5D5C0;transition:background 0.3s;}
.essai-dot.used{background:#E8724A;}
.essai-dot.ok{background:#2A9D8F;}
.btn-repete{font-family:'Quicksand',sans-serif;font-weight:700;font-size:0.95rem;padding:12px 28px;border-radius:16px;border:none;cursor:pointer;background:#E8724A;color:white;box-shadow:0 4px 0 rgba(0,0,0,0.12);transition:all 0.15s;display:flex;align-items:center;gap:8px;margin:0 auto;}
.btn-repete:hover{transform:translateY(-2px);}
.btn-repete:active{transform:translateY(2px);}
.btn-repete.listening{background:#E76F51;animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{box-shadow:0 4px 0 rgba(0,0,0,0.12)}50%{box-shadow:0 4px 20px rgba(231,111,81,0.5)}}
.btn-repete:disabled{opacity:0.4;cursor:default;transform:none;animation:none;}
.transcrit{font-family:'Andika',sans-serif;font-size:0.75rem;color:#888;margin-top:8px;min-height:18px;font-style:italic;}
.invented-box{background:white;border-radius:16px;padding:12px;border:2.5px solid #F4A261;text-align:center;cursor:pointer;transition:transform 0.15s;margin-top:6px;}
.invented-box:hover{transform:scale(1.02);}
.invented-title{font-size:0.78rem;color:#E8724A;font-weight:700;margin-bottom:6px;font-family:'Andika',sans-serif;}
.invented-desc{font-size:0.65rem;color:#C49A7A;margin-top:6px;}
.dots{display:inline-flex;gap:5px;padding:6px 0;}
.dots span{width:8px;height:8px;border-radius:50%;background:#F4A261;animation:dot 1s infinite;}
.dots span:nth-child(2){animation-delay:0.18s;}
.dots span:nth-child(3){animation-delay:0.36s;}
@keyframes dot{0%,80%,100%{transform:scale(0.5);opacity:0.3}40%{transform:scale(1);opacity:1}}
.api-note{text-align:center;font-size:0.62rem;color:#D4B49A;margin-top:10px;font-family:'Quicksand',sans-serif;}

/* ── ÉCRAN DE SÉLECTION ÉLÈVE ── */
#selection-screen{
  position:fixed;inset:0;background:#F5EDE4;
  display:flex;align-items:center;justify-content:center;
  z-index:1000;padding:20px;
}
.selection-card{
  background:#FFF9F0;border-radius:24px;
  padding:2rem 1.8rem;max-width:420px;width:100%;
  box-shadow:0 8px 32px rgba(232,114,74,0.15);
  text-align:center;
}
.selection-card h2{
  font-size:1.5rem;font-weight:700;color:#E8724A;margin-bottom:0.3rem;
}
.selection-card p{
  font-size:0.82rem;color:#C49A7A;font-weight:600;margin-bottom:1.6rem;
}
.prenom-grid{
  display:flex;flex-wrap:wrap;gap:10px;
  justify-content:center;margin-bottom:1.4rem;
}
.prenom-btn{
  font-family:'Quicksand',sans-serif;font-weight:700;
  font-size:0.95rem;padding:10px 20px;border-radius:50px;
  border:2.5px solid #E8724A;background:white;color:#E8724A;
  cursor:pointer;transition:all 0.18s;
}
.prenom-btn:hover{background:#E8724A;color:white;transform:translateY(-2px);}
.selection-empty{
  font-size:0.85rem;color:#C49A7A;font-style:italic;
  background:#FFF0E8;border-radius:12px;padding:16px;
  margin-bottom:1rem;line-height:1.6;
}
.btn-teacher-link{
  display:inline-block;font-family:'Quicksand',sans-serif;
  font-weight:600;font-size:0.78rem;color:#2A9D8F;
  text-decoration:none;border:2px solid #2A9D8F;
  border-radius:50px;padding:7px 16px;transition:all 0.18s;
  margin-top:0.4rem;
}
.btn-teacher-link:hover{background:#2A9D8F;color:white;}
.eleve-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:#E1F5F3;border:2px solid #2A9D8F;
  border-radius:50px;padding:6px 14px;
  font-size:0.82rem;font-weight:700;color:#1D7A6E;
  cursor:pointer;transition:all 0.18s;
}
.eleve-badge:hover{background:#2A9D8F;color:white;}
</style>
</head>
<body>

<!-- ══ ÉCRAN DE SÉLECTION ÉLÈVE ══ -->
<div id="selection-screen">
  <div class="selection-card">
    <div style="font-size:2.5rem;margin-bottom:0.5rem;">🧩</div>
    <h2>SyllaboJeu</h2>
    <p>Qui joue aujourd'hui ?</p>
    <div class="prenom-grid" id="prenom-grid">
      <div class="dots"><span></span><span></span><span></span></div>
    </div>
    <div id="selection-empty" style="display:none;">
      <div class="selection-empty">
        Aucun élève n'est encore configuré.<br>
        L'enseignant doit d'abord créer la liste de la classe dans l'espace enseignant.
      </div>
      <a href="teacher.html" class="btn-teacher-link">⚙️ Espace enseignant</a>
    </div>
  </div>
</div>

<canvas id="emoji-canvas" width="150" height="150"></canvas>
<div id="app" style="display:none;">
  <h1>🧩 SyllaboJeu</h1>
  <p class="tagline">Recompose l'image pour trouver le mot !</p>
  <div class="score-row">
    <div id="stars">⭐⭐⭐</div>
    <div id="mode-badge" class="mode-badge mode-ia">🤖 Mode IA</div>
    <div style="display:flex;align-items:center;gap:8px;">
      <div>Score : <strong id="score" style="color:#E8724A;">0</strong></div>
      <button class="btn-end-session" onclick="ouvrirFinSession()" title="Terminer la session">⏹ Fin</button>
    </div>
  </div>

  <!-- Badge élève connecté -->
  <div style="display:flex;justify-content:center;margin-bottom:0.7rem;">
    <div class="eleve-badge" onclick="changerEleve()" title="Changer d'élève">
      👤 <span id="eleve-nom-badge">—</span>
      <span style="font-size:0.7rem;opacity:0.7;">· changer</span>
    </div>
  </div>

  <div class="top-controls">
    <div class="level-bar">
      <button class="lvl-btn active" onclick="setLevel(1)">Niveau 1 — 2 syllabes</button>
      <button class="lvl-btn" onclick="setLevel(2)">Niveau 2 — 3 syllabes</button>
      <button class="lvl-btn" onclick="setLevel(3)">Niveau 3 — 4 syllabes</button>
    </div>
    <button class="btn-perso" id="btn-perso" onclick="togglePerso()">⚙️ Personnaliser</button>
  </div>

  <div id="perso-panel">
    <div class="perso-title">⚙️ Mots de l'enseignant·e</div>
    <div class="perso-desc">Tapez un mot et son découpage en syllabes séparées par des tirets, puis cliquez <strong>+ Ajouter</strong>. Cliquez sur l'emoji pour le changer.</div>
    <div class="add-form">
      <input id="inp-mot" type="text" placeholder="ex: argent">
      <input id="inp-syls" type="text" placeholder="ex: ar-gent">
      <button class="btn-add" onclick="addWord()">+ Ajouter</button>
    </div>
    <div class="word-list" id="word-list"><div style="font-size:0.7rem;color:#C49A7A;text-align:center;padding:8px;">Aucun mot ajouté</div></div>
    <div id="emoji-picker">
      <div class="emoji-picker-title">Choisissez un emoji</div>
      <div class="emoji-cats" id="emoji-cats"></div>
      <div class="emoji-grid" id="emoji-grid"></div>
    </div>
    <div class="perso-btns">
      <button class="btn-small btn-reset-perso" onclick="resetPerso()">🔄 Retour mode IA</button>
      <button class="btn-small btn-apply" onclick="applyPerso()">✅ Jouer avec ces mots</button>
    </div>
  </div>

  <div class="main-area">
    <div class="puzzle-wrap">
      <div class="puzzle-label">Le puzzle</div>
      <div id="puzzle-outer"><div class="dots"><span></span><span></span><span></span></div></div>
    </div>
    <div class="drop-area">
      <div class="drop-label">Pose les syllabes dans le bon ordre</div>
      <div class="target-zone" id="target-zone">
        <span style="font-size:0.85rem;color:#D4B49A;font-family:'Andika',sans-serif;">clique sur une syllabe...</span>
      </div>
      <div id="invented-container"></div>
    </div>
  </div>

  <div id="prononce-zone">
    <div class="prononce-title" id="prononce-title">🔊 Écoute bien et répète !</div>
    <div class="smiley-row" id="smiley">🙂</div>
    <div class="smiley-msg" id="smiley-msg"></div>
    <div class="essais-row" id="essais-row"></div>
    <button class="btn-repete" id="btn-repete" onclick="startListening()">
      <span id="repete-icon">🎤</span>
      <span id="repete-label">Je répète !</span>
    </button>
    <div class="transcrit" id="transcrit"></div>
  </div>

  <div class="pool-area">
    <div class="pool-label">Syllabes mélangées — clique pour entendre le mot</div>
    <div class="pool-row" id="pool"></div>
  </div>
  <div class="speaking-bar" id="speaking-bar"></div>
  <div class="btns">
    <button class="btn btn-placed" id="btn-placed" onclick="listenPlaced()" disabled>👂 Ma tentative</button>
    <button class="btn btn-reset" onclick="resetWord()">🔄 Recommencer</button>
    <button class="btn btn-validate" id="btn-validate" onclick="validateWord()">✅ Valider</button>
    <button class="btn btn-next" id="btn-next" onclick="nextWord()" style="display:none">➡️ Mot suivant</button>
  </div>
  <div class="feedback" id="feedback"></div>
  <div class="api-note">⚠️ Nécessite une clé API Google Gemini et une connexion internet. Microphone requis pour la répétition orale (Chrome recommandé).</div>
</div>

