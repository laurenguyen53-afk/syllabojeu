function startListening(){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR){
    document.getElementById('transcrit').textContent='Reconnaissance vocale non disponible — utilise Chrome.';
    document.getElementById('smiley').textContent='🤷';
    document.getElementById('smiley-msg').textContent='Active le microphone dans Chrome !';
    document.getElementById('btn-repete').disabled=true;
    document.getElementById('btn-next').style.display='flex';
    // Sauvegarder sans résultat oral
    sauvegarderResultat(currentWord.mot, _syllabationReussie, '😐', 0, '😄');
    return;
  }
  const btn=document.getElementById('btn-repete');
  btn.classList.add('listening');
  document.getElementById('repete-icon').textContent='🔴';
  document.getElementById('repete-label').textContent='J\'écoute...';
  btn.disabled=true;
  document.getElementById('transcrit').textContent='';

  const rec=new SR();
  rec.lang='fr-FR'; rec.interimResults=false; rec.maxAlternatives=3;

  rec.onresult=(e)=>{
    const results=Array.from(e.results[0]).map(r=>r.transcript);
    const scores=results.map(r=>scoreSimilarite(currentWord.mot,r));
    const maxScore=Math.max(...scores);
    const best=results[0];
    document.getElementById('transcrit').textContent='J\'ai entendu : "'+best+'"';
    btn.classList.remove('listening');
    handlePrononceResult(maxScore);
  };

  rec.onerror=(e)=>{
    btn.classList.remove('listening');
    if(e.error==='no-speech'){
      document.getElementById('transcrit').textContent='Je n\'ai rien entendu... réessaie !';
      handlePrononceResult(0);
    } else if(e.error==='not-allowed'){
      document.getElementById('transcrit').textContent='Microphone bloqué — autorise-le dans Chrome !';
      document.getElementById('btn-next').style.display='flex';
      btn.disabled=true;
      sauvegarderResultat(currentWord.mot, _syllabationReussie, '😐', 0, '😄');
    } else {
      document.getElementById('transcrit').textContent='Erreur microphone : '+e.error;
      handlePrononceResult(0);
    }
  };

  rec.onend=()=>{ btn.classList.remove('listening'); };
  rec.start();
}

function handlePrononceResult(sc){
  prononceEssais++;
  _essaisCourants = prononceEssais;
  const {smiley,msg,couleur}=getSmiley(sc);
  _smileyCourant = smiley;
  document.getElementById('smiley').textContent=smiley;
  document.getElementById('smiley-msg').textContent=msg;
  document.getElementById('smiley-msg').style.color=couleur;
  renderEssaisDots();
  const btn=document.getElementById('btn-repete');
  btn.classList.remove('listening');

  if(sc>=0.85){
    btn.disabled=true;
    document.getElementById('repete-icon').textContent='✅';
    document.getElementById('repete-label').textContent='Bravo !';
    // Sauvegarder : réussi
    sauvegarderResultat(currentWord.mot, _syllabationReussie, '😄', prononceEssais, '😄');
    speak('Bravo ! Très bonne prononciation !',0.9,()=>{
      document.getElementById('btn-next').style.display='flex';
    });
  } else if(prononceEssais>=prononceMax){
    btn.disabled=true;
    // Sauvegarder : dernier essai
    sauvegarderResultat(currentWord.mot, _syllabationReussie, smiley, prononceEssais, '😄');
    speak(currentWord.mot,0.5,()=>{
      document.getElementById('prononce-title').textContent='💪 Continue ! Écoute encore une fois...';
      setTimeout(()=>{document.getElementById('btn-next').style.display='flex';},1200);
    });
  } else {
    const restants=prononceMax-prononceEssais;
    document.getElementById('prononce-title').textContent='🎤 Réessaie ! ('+restants+' essai'+(restants>1?'s':'')+' restant'+(restants>1?'s':'')+')';
    btn.disabled=false; btn.classList.remove('listening');
    document.getElementById('repete-icon').textContent='🎤';
    document.getElementById('repete-label').textContent='Réessayer';
    setTimeout(()=>speak(currentWord.mot,0.55),800);
  }
}

