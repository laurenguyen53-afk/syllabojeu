function shuffle(a){let b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}return b;}

// ══ RECONNAISSANCE VOCALE ══
function normalise(str){
  return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z]/g,'').trim();
}

function levenshtein(a,b){
  const m=a.length,n=b.length;
  const dp=Array.from({length:m+1},(_,i)=>Array.from({length:n+1},(_,j)=>i===0?j:j===0?i:0));
  for(let i=1;i<=m;i++)
    for(let j=1;j<=n;j++)
      dp[i][j]=a[i-1]===b[j-1]?dp[i-1][j-1]:1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
  return dp[m][n];
}

function terminaisonNasale(str){
  return /(?:in|ain|ein|un|on|an|en)$/i.test(str);
}

function scoreSimilarite(cible,entendu){
  const nc=normalise(cible),ne=normalise(entendu);
  if(nc===ne)return 1.0;
  const dist=levenshtein(nc,ne);
  const maxLen=Math.max(nc.length,ne.length);
  let score=1-(dist/maxLen);
  if(terminaisonNasale(nc)){
    if(ne===nc+'e'||ne===nc.replace(/n$/,'ne')){score=Math.min(score,0.6);}
    const neCompact=ne.replace(/\s/g,'');
    if(neCompact===nc+'e'){score=Math.min(score,0.6);}
  }
  if(ne.length>nc.length*2||nc.length>ne.length*2){score=score*0.65;}
  const neNoSpace=ne.replace(/\s/g,'');
  if(neNoSpace===nc)return 1.0;
  if(ne.split(' ').some(w=>w===nc))return Math.max(score,0.9);
  return score;
}

function getSmiley(score){
  if(score>=0.88)return{smiley:'😄',msg:'Bravo ! Tu as bien prononcé !',couleur:'#2A9D8F'};
  if(score>=0.65)return{smiley:'😐',msg:'Pas mal... encore un essai !',couleur:'#E9C46A'};
  return{smiley:'😬',msg:'Presque ! On réessaie ?',couleur:'#E76F51'};
}

